# =============================================================================
# Mike Platform — Environment Configuration
# Copy to .env and fill in values: cp .env.example .env
# =============================================================================

# --- Postgres ---
POSTGRES_USER=mike
POSTGRES_PASSWORD=changeme-generate-random-32-chars
POSTGRES_DB=mike
DATABASE_URL=postgresql://mike:changeme-generate-random-32-chars@postgres:5432/mike

# --- GoTrue (Auth) ---
GOTRUE_JWT_SECRET=changeme-generate-random-64-chars
GOTRUE_JWT_EXP=3600
GOTRUE_SITE_URL=http://localhost
GOTRUE_URI_ALLOW_LIST=http://localhost:3000
GOTRUE_DISABLE_SIGNUP=false
GOTRUE_MAILER_AUTOCONFIRM=true
GOTRUE_DB_DRIVER=postgres
GOTRUE_DB_DATABASE_URL=postgresql://mike:changeme-generate-random-32-chars@postgres:5432/mike?sslmode=disable

# --- PostgREST ---
PGRST_DB_URI=postgresql://mike:changeme-generate-random-32-chars@postgres:5432/mike
PGRST_DB_ANON_ROLE=anon
PGRST_JWT_SECRET=changeme-generate-random-64-chars

# --- MinIO (S3-compatible storage) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme-generate-random-32-chars
R2_ENDPOINT_URL=http://minio:9000
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=changeme-generate-random-32-chars
R2_BUCKET_NAME=mike

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- Backend ---
PORT=3001
FRONTEND_URL=http://localhost
DOWNLOAD_SIGNING_SECRET=changeme-generate-random-32-chars
USER_API_KEYS_ENCRYPTION_SECRET=changeme-generate-random-64-chars
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
RESEND_API_KEY=

# --- Frontend ---
NEXT_PUBLIC_SUPABASE_URL=http://localhost:9999
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=changeme-gotrue-anon-key
NEXT_PUBLIC_API_BASE_URL=http://localhost/api

# --- GlitchTip (error tracking) ---
GLITCHTIP_SECRET_KEY=changeme-generate-random-50-chars
GLITCHTIP_DOMAIN=http://localhost:8000
GLITCHTIP_DSN=
SENTRY_DSN=

# --- pgAdmin ---
PGADMIN_DEFAULT_EMAIL=admin@mike.local
PGADMIN_DEFAULT_PASSWORD=changeme-generate-random-16-chars

# --- Rate Limiting (optional overrides) ---
# RATE_LIMIT_GENERAL_WINDOW_MINUTES=15
# RATE_LIMIT_GENERAL_MAX=300
# RATE_LIMIT_CHAT_WINDOW_MINUTES=15
# RATE_LIMIT_CHAT_MAX=30
# RATE_LIMIT_UPLOAD_WINDOW_HOURS=1
# RATE_LIMIT_UPLOAD_MAX=50
